// Solar Property Exchange — Prisma schema
// Mirrors the PRD table list: users, warehouses, warehouse_units, solar_assets,
// energy_shares, energy_trades, ev_chargers, charging_sessions, auctions, bids.

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  OWNER
  TENANT
  INVESTOR
  DRIVER
  ADMIN
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  LEASED
  AUCTIONING
  SOLD
}

enum ChargerType {
  AC_SLOW
  AC_FAST
  DC_RAPID
  DC_ULTRA_RAPID
}

enum ChargerStatus {
  AVAILABLE
  OCCUPIED
  OFFLINE
  RESERVED
}

enum ChargingSessionStatus {
  RESERVED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum TradeStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum TradeSide {
  BUY
  SELL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  name          String
  email         String   @unique
  role          UserRole @default(TENANT)
  stripeAccountId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  warehousesOwned   Warehouse[]        @relation("WarehouseOwner")
  energyShares      EnergyShare[]
  bids              Bid[]
  trades            EnergyTrade[]      @relation("OrderOwnerTrades")
  matchedTrades     EnergyTrade[]      @relation("CounterpartyTrades")
  chargingSessions  ChargingSession[]
  payments          Payment[]
  unitLeases        WarehouseUnit[]    @relation("UnitTenant")

  @@map("users")
}

model Warehouse {
  id                  String   @id @default(uuid())
  name                String
  address             String
  latitude            Float
  longitude           Float
  // PostGIS point, kept in sync with latitude/longitude via a DB trigger
  // (see prisma/migrations/.../migration.sql) so ST_DWithin radius search works.
  description         String?
  photos              String[] @default([])
  videos              String[] @default([])
  floorPlans          String[] @default([])
  totalUnits          Int      @default(0)
  ownerId             String
  owner               User     @relation("WarehouseOwner", fields: [ownerId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  units        WarehouseUnit[]
  solarAsset   SolarAsset?
  evChargers   EvCharger[]
  energyShares EnergyShare[]
  auctions     Auction[]

  @@index([ownerId])
  @@map("warehouses")
}

model WarehouseUnit {
  id            String     @id @default(uuid())
  warehouseId   String
  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  unitNumber    String
  sqft          Int
  status        UnitStatus @default(AVAILABLE)
  monthlyRent   Decimal    @db.Decimal(10, 2)
  availableDate DateTime?
  tenantId      String?
  tenant        User?      @relation("UnitTenant", fields: [tenantId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([warehouseId, unitNumber])
  @@index([status])
  @@map("warehouse_units")
}

model SolarAsset {
  id                String    @id @default(uuid())
  warehouseId       String    @unique
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  capacityKw        Float
  annualGenerationKwh Float
  batteryCapacityKwh Float    @default(0)
  currentProductionKw Float   @default(0)
  // Daily production history for the "Historical Production" chart.
  productionHistory  ProductionRecord[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("solar_assets")
}

model ProductionRecord {
  id            String     @id @default(uuid())
  solarAssetId  String
  solarAsset    SolarAsset @relation(fields: [solarAssetId], references: [id], onDelete: Cascade)
  date          DateTime
  generatedKwh  Float

  @@unique([solarAssetId, date])
  @@index([solarAssetId, date])
  @@map("solar_production_records")
}

model EnergyShare {
  id              String   @id @default(uuid())
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  sharePercentage Float
  annualKwh       Float
  ownerId         String?
  owner           User?    @relation(fields: [ownerId], references: [id])
  purchasePrice   Decimal? @db.Decimal(12, 2)
  internalRatePerKwh Decimal @db.Decimal(6, 4) @default(0.09)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auctions Auction[]

  @@index([warehouseId])
  @@index([ownerId])
  @@map("energy_shares")
}

model EnergyTrade {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation("OrderOwnerTrades", fields: [userId], references: [id])
  counterpartyId String?
  counterparty User?     @relation("CounterpartyTrades", fields: [counterpartyId], references: [id])
  side         TradeSide // BUY or SELL, from userId's perspective
  quantityKwh  Float
  filledKwh    Float     @default(0)
  pricePerKwh  Decimal   @db.Decimal(6, 4)
  status       TradeStatus @default(OPEN)
  warehouseId  String?
  timestamp    DateTime  @default(now())

  @@index([status, side])
  @@index([warehouseId])
  @@map("energy_trades")
}

model EvCharger {
  id           String        @id @default(uuid())
  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  label        String
  chargerType  ChargerType
  powerKw      Float
  status       ChargerStatus @default(AVAILABLE)
  pricePerKwh  Decimal       @db.Decimal(6, 4)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions ChargingSession[]

  @@index([warehouseId, status])
  @@map("ev_chargers")
}

model ChargingSession {
  id              String                 @id @default(uuid())
  userId          String
  user            User                   @relation(fields: [userId], references: [id])
  chargerId       String
  charger         EvCharger              @relation(fields: [chargerId], references: [id])
  status          ChargingSessionStatus  @default(RESERVED)
  reservedStart   DateTime?
  reservedDuration Int?                  // minutes
  energyDeliveredKwh Float                @default(0)
  solarPercentage Float                  @default(0)
  cost            Decimal?               @db.Decimal(10, 2)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime               @default(now())

  payment Payment?

  @@index([chargerId, status])
  @@map("charging_sessions")
}

model Auction {
  id              String        @id @default(uuid())
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  energyShareId   String?
  energyShare     EnergyShare?  @relation(fields: [energyShareId], references: [id])
  sharePercentage Float
  reservePrice    Decimal       @db.Decimal(12, 2)
  currentPrice    Decimal       @db.Decimal(12, 2)
  startDate       DateTime      @default(now())
  endDate         DateTime
  status          AuctionStatus @default(SCHEDULED)
  winningBidId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bids Bid[]

  @@index([status, endDate])
  @@map("auctions")
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  timestamp DateTime @default(now())

  @@index([auctionId, amount])
  @@map("bids")
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  stripePaymentIntentId String?       @unique
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("gbp")
  status                PaymentStatus @default(PENDING)
  chargingSessionId     String?       @unique
  chargingSession       ChargingSession? @relation(fields: [chargingSessionId], references: [id])
  description           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("payments")
}
